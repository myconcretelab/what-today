# Required: `contrats` API base URL (example: http://localhost:4000)
CONTRATS_API_BASE_URL=
# Recommended: dedicated token configured on `contrats` as INTEGRATION_API_TOKEN
CONTRATS_API_TOKEN=
# Optional fallback auth (if token is not used)
CONTRATS_API_BASIC_USER=what-today
CONTRATS_API_BASIC_PASSWORD=
# Optional explicit mapping what-today gite -> contrats gite id or prefix
# JSON example: {"phonsine":"cuid_gite_1","gree":"GRE"}
CONTRATS_GITE_MAP=

#!/usr/bin/env bash
set -euo pipefail

before_lock_hash='';
if [[ -f package-lock.json ]]; then
  before_lock_hash="$(shasum package-lock.json | awk '{print $1}')";
fi

echo "[update] Pulling latest changes..."
git pull

after_lock_hash='';
if [[ -f package-lock.json ]]; then
  after_lock_hash="$(shasum package-lock.json | awk '{print $1}')";
fi

if [[ "${before_lock_hash}" != "${after_lock_hash}" ]]; then
  echo "[update] Lockfile changed. Running npm ci..."
  npm ci
else
  echo "[update] Lockfile unchanged. Skipping npm ci."
fi

echo "[update] Building frontend..."
npm run build

echo "[update] Done."
